{
  "name": "avok.js",
  "private": true,
  "version": "0.0.1",
  "description": "avok.js: SDK for passkey-authenticated, self-custodial smart wallets \u2014 EVM and Solana.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "lint": "biome lint --error-on-warnings",
    "format": "biome format --write",
    "format:check": "biome format",
    "build": "pnpm -r --filter './packages/*' --filter './contracts' build",
    "test": "pnpm check:wiring && pnpm format:check && pnpm lint && pnpm build && pnpm typecheck && pnpm -r --filter './packages/*' --filter './contracts' test",
    "typecheck": "pnpm -r --filter './packages/*' --filter './contracts' typecheck",
    "check": "pnpm test",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" exec tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:packages": "pnpm -r --parallel --filter \"./packages/*\" exec tsc -p tsconfig.json --watch --preserveWatchOutput",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "check:wiring": "node scripts/check-test-wiring.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "ioredis": "^5.11.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "uuid@<11.1.1": ">=11.1.1",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "@changesets/parse>js-yaml": ">=4.2.0",
      "@expo/xcpretty>js-yaml": ">=4.2.0"
    }
  }
}
