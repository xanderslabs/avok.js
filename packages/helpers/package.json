{
  "name": "@avokjs/helpers",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./qr": {
      "types": "./dist/qr.d.ts",
      "import": "./dist/qr.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@avokjs/vanilla": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@avokjs/vanilla": {
      "optional": true
    }
  },
  "dependencies": {
    "@avokjs/contracts": "workspace:*",
    "viem": "^2.54.6",
    "@solana/kit": "^6.10.0",
    "@solana-name-service/sns-sdk-kit": "0.10.0",
    "qrcode": "^1.5.4",
    "jsqr": "^1.4.0",
    "@solana-program/token": "^0.13.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@avokjs/vanilla": "workspace:*"
  }
}
