{
  "name": "@avokjs/shared-origin",
  "version": "0.0.1",
  "description": "Shared-origin connection client for Avok: the browser counterpart to the auth-origin popup.",
  "keywords": [
    "eip-7702",
    "wallet",
    "oidc",
    "avok"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/shared-origin"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@scure/base": "^2.2.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "vitest": "^4.1.10"
  }
}
