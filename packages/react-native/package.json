{
  "name": "@avokjs/react-native",
  "version": "0.0.1",
  "description": "React Native facade for Avok: AvokProvider + hooks + native passkey and SecureStore wiring (own-origin).",
  "keywords": [
    "react-native",
    "expo",
    "wallet",
    "avok",
    "eip-7702",
    "passkey",
    "webauthn"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/react-native"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "VERIFICATION.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && tsup",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@avokjs/contracts": "workspace:*",
    "@avokjs/core": "workspace:*",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@solana-program/compute-budget": "^0.17.0",
    "@solana-program/token": "^0.15.0",
    "@solana/kit": "^7.0.0",
    "micro-key-producer": "^0.9.0",
    "viem": "^2.55.4"
  },
  "peerDependencies": {
    "expo-secure-store": ">=57.0.0",
    "react": ">=19.2.7",
    "react-native": ">=0.86.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
