{
  "name": "@avokjs/auth-origin",
  "version": "0.0.1",
  "description": "The static, clone-and-own auth-origin popup template for Avok: the shared-origin connect + sign popups. No server, no OIDC, no tokens, no secret.",
  "keywords": [
    "eip-7702",
    "wallet",
    "webauthn",
    "avok"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/auth-origin"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "app-inlined",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:app": "node scripts/build-app.mjs && node scripts/inline-app.mjs",
    "build": "tsup && pnpm run build:app",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json && tsc -p app/tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@scure/base": "^2.2.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@avokjs/contracts": "workspace:*",
    "@avokjs/design": "workspace:*",
    "@avokjs/react": "workspace:*",
    "@avokjs/solana-txengine": "workspace:*",
    "@avokjs/vanilla": "workspace:*",
    "@avokjs/wallet-core": "workspace:*",
    "@noble/curves": "^2.2.0",
    "@solana/kit": "^6.10.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
