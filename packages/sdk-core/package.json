{
  "name": "@avokjs/sdk-core",
  "version": "0.0.1",
  "description": "SDK core package for Avok: platform-agnostic facades and utilities.",
  "keywords": [
    "sdk",
    "wallet",
    "avok"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/sdk-core"
  },
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@avokjs/contracts": "workspace:*",
    "@avokjs/network": "workspace:*",
    "@avokjs/oracle": "workspace:*",
    "@avokjs/solana-txengine": "workspace:*",
    "@avokjs/txengine": "workspace:*",
    "@avokjs/wallet-core": "workspace:*",
    "@scure/base": "^2.2.0",
    "@solana/kit": "^6.10.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@noble/curves": "^2.2.0",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
