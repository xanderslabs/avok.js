{
  "name": "@avokjs/vanilla",
  "version": "0.0.1",
  "description": "Framework-agnostic web front door for Avok: own-origin + lazy shared-origin connection (WebAuthn + localStorage).",
  "keywords": [
    "eip-7702",
    "wallet",
    "passkey",
    "webauthn",
    "avok"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/vanilla"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@avokjs/contracts": "workspace:*",
    "@avokjs/shared-origin": "workspace:*",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@solana-program/compute-budget": "^0.16.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.10.0",
    "micro-key-producer": "^0.9.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@avokjs/provider": "workspace:*",
    "@avokjs/sdk-core": "workspace:*",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/wallet": "^1.1.0",
    "@avokjs/solana-txengine": "workspace:*",
    "@avokjs/txengine": "workspace:*",
    "@avokjs/wallet-core": "workspace:*",
    "@types/node": "^26.1.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
