{
  "name": "@avokjs/react",
  "version": "0.0.1",
  "description": "React facade for Avok: AvokProvider + hooks (web).",
  "keywords": [
    "react",
    "wallet",
    "avok",
    "eip-7702",
    "passkey",
    "webauthn"
  ],
  "type": "module",
  "license": "MIT",
  "author": "kamsich02",
  "homepage": "https://github.com/xanderslabs/avok.js#readme",
  "bugs": {
    "url": "https://github.com/xanderslabs/avok.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xanderslabs/avok.js.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && tsup",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@avokjs/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
