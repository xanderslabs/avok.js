{
  "name": "@avokjs/design",
  "version": "0.0.1",
  "description": "Avok design tokens + CSP-safe CSS generators and inline Lucide icons for the ceremony popups and app facades. Internal (workspace-only): consumed by auth-origin's popup app + the example demos; not published.",
  "keywords": ["design-tokens", "avok", "wallet"],
  "type": "module",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": { "build": "tsc -p tsconfig.json", "typecheck": "tsc --noEmit -p tsconfig.typecheck-tests.json", "test": "vitest run" },
  "engines": { "node": ">=22.5.0" },
  "devDependencies": { "@types/node": "^26.1.0", "vitest": "^4.1.10" }
}
